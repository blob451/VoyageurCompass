# ============================================
# VoyageurCompass Staging Environment Configuration
# ============================================
# Copy this file to .env.staging and fill in the values
# Staging should mirror production as closely as possible

# ============================================
# Django Core Settings
# ============================================
# REQUIRED: Generate a unique secret key for staging
SECRET_KEY=

# Can be True for debugging, but prefer False
DEBUG=False

# REQUIRED: Add your staging domain
# Example: staging.voyageurcompass.com
ALLOWED_HOSTS=

# REQUIRED: Staging site URL
SITE_URL=

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# REQUIRED: Staging database (separate from production)
DB_NAME=voyageur_compass_staging
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# Connection pooling
CONN_MAX_AGE=300

# ============================================
# Redis Cache & Celery Configuration
# ============================================
# REQUIRED: Redis connection (can share with production or separate)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=3  # Different DB number than production

# Celery configuration
CELERY_BROKER_URL=redis://:{REDIS_PASSWORD}@{REDIS_HOST}:{REDIS_PORT}/4
CELERY_RESULT_BACKEND=redis://:{REDIS_PASSWORD}@{REDIS_HOST}:{REDIS_PORT}/5

# ============================================
# Security Settings (Less strict than production)
# ============================================
# CORS configuration
CORS_ALLOWED_ORIGINS=

# CSRF settings
CSRF_TRUSTED_ORIGINS=
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True

# Security headers (can be less strict)
SECURE_SSL_REDIRECT=False  # May not have SSL in staging
SECURE_HSTS_SECONDS=3600  # Shorter for testing

# ============================================
# Email Configuration
# ============================================
# Use mail trap or similar for staging
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=staging@voyageurcompass.com

# ============================================
# Monitoring & Logging
# ============================================
# More verbose logging for staging
LOG_LEVEL=DEBUG
DJANGO_LOG_LEVEL=INFO

# Sentry (optional, different project)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging

# ============================================
# API & External Services
# ============================================
# Yahoo Finance API (can use test/sandbox API)
YAHOO_FINANCE_API_KEY=
YAHOO_FINANCE_API_TIMEOUT=60  # Longer timeout for testing
DATA_REFRESH_INTERVAL=300  # More frequent updates for testing

# ============================================
# Performance Settings (Lower than production)
# ============================================
WEB_CONCURRENCY=2
GUNICORN_WORKERS=2
GUNICORN_THREADS=1
GUNICORN_TIMEOUT=60  # Longer for debugging

# ============================================
# Feature Flags (For testing new features)
# ============================================
ENABLE_REGISTRATION=True
ENABLE_SOCIAL_AUTH=True  # Test new features
ENABLE_TWO_FACTOR_AUTH=True  # Test new features
ENABLE_API_DOCUMENTATION=True  # Enable for testing
MAINTENANCE_MODE=False

# ============================================
# Testing & Development
# ============================================
ENABLE_DEBUG_TOOLBAR=True
ENABLE_SILK_PROFILING=True
TEST_MODE=False
STAGING_MODE=True

# ============================================
# Blue-Green Deployment
# ============================================
DEPLOYMENT_COLOR=blue
DEPLOYMENT_HEALTH_CHECK_PATH=/api/health/